# Simple auth (defaults shown — override in .env.local)
AUTH_USERNAME=admin
AUTH_PASSWORD=portfolio
AUTH_DISPLAY_NAME=Admin
AUTH_SECRET=portfolio-dev-secret

# Portfolio API — pick one:
# (A) Local Functions (requires portfolio-api on port 7071): use npm run dev:local-api
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_URL=http://localhost:7071/api
NEXT_PUBLIC_DEFAULT_HOUSEHOLD_ID=local-household

# (B) Dev Azure API (recommended for UI work — Architect, Analyzer, etc.):
# cp env/local-against-dev.env.example .env.local
# Or rely on committed .env.development when running npm run dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
