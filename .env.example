# Simple auth (defaults shown — override in .env.local)
AUTH_USERNAME=admin
AUTH_PASSWORD=portfolio
AUTH_DISPLAY_NAME=Admin
AUTH_SECRET=portfolio-dev-secret

# Portfolio API (local Azure Functions)
NEXT_PUBLIC_API_URL=http://localhost:7071/api
NEXT_PUBLIC_DEFAULT_HOUSEHOLD_ID=local-household

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
